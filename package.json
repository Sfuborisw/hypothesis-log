{
  "name": "hypothesis-log",
  "private": true,
  "description": "Run the FastAPI backend and Vite frontend together.",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "cd backend && .venv/bin/python -m uvicorn app.main:app --reload --port 8001",
    "dev:web": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
